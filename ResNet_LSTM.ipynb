        "k=MaxPooling2D(pool_size=(1, 2)) (k)\n",
        "\n",
        "d=TimeDistributed(Flatten())(k)\n",
        "\n",
        "#------------------------------------------------------------------------------\n",
        "#LSTEM BLOCK\n",
        "#------------------------------------------------------------------------------\n",
        "d=LSTM(64,activation='relu', return_sequences=True,)(d)\n",
        "d=LSTM(64,activation='relu', return_sequences=False,)(d)\n",
        "\n",
        "#-----------------------------------------------------------------------------\n",
        "#output layer\n",
        "#-------------------------------------------------------------------------\n",
        "d=Dense(10, activation ='softmax',kernel_initializer='he_normal')(d)\n",
        "\n",
        "model=Model(inputs=input,outputs=d)\n",
        "epochs = 100\n",
        "opt=Adam(learning_rate=.0001)\n",
        "model.compile(optimizer =opt, loss = 'categorical_crossentropy',  metrics = ['accuracy'])\n",
        "model.summary()\n",
        "history=model.fit(x_train, y_train,validation_split=0.15,batch_size=64,epochs=25)\n",
        "model.save(\"/content/drive/MyDrive/Colab Notebooks/resent_lstm.h5\")"
      ]
    },
