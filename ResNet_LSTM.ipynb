        "file =  open(\"/content/drive/MyDrive/Colab Notebooks/signaldataset/RML2016.10b.dat\",\"rb\")\n",
        "Xd = pickle.load(file, encoding = 'latin')\n",
        "snrs, mods = map(lambda j: sorted(list(set(map(lambda x: x[j], Xd.keys())))), [1,0])\n",
        "X = []\n",
        "lbl = []\n",
        "for mod in mods:\n",
        "    for snr in snrs:\n",
        "        X.append(Xd[(mod,snr)])\n",
        "        for i in range(Xd[(mod,snr)].shape[0]):  lbl.append((mod,snr))\n",
        "\n",
        "X = np.vstack(X)\n",
        "lbl=np.array(lbl)\n",
        "print(lbl.shape)"
      ]
    },
