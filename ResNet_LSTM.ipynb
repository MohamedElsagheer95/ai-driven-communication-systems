      "source": [
        "def snr_accuracy(snr_test,y_test,x_test,y_pred):\n",
        "\n",
        "  Y_test=np.argmax(y_test,axis=1)\n",
        "  y_predict=np.argmax(y_pred,axis=1)\n",
        "  un=np.unique(snr_test)\n",
        "  sorted_snrs = np.sort(un)\n",
        "  print(sorted_snrs)\n",
        "  xx_axis = []\n",
        "  yy_axis = []\n",
        "  for snr in sorted_snrs:\n",
        "\n",
        "\n",
        "    idx = np.where(snr_test == snr)\n",
        "\n",
        "    xx_axis.append(snr)\n",
        "    yy_axis.append(accuracy_score(Y_test[idx[0]],y_predict[idx[0]]))\n",
        "  print(df(data = np.array(yy_axis).reshape(1, -1) * 100,  columns = sorted_snrs, index = ['accuracy']).round(2))\n",
        "  print(yy_axis)\n",
        "  return np.array(xx_axis),np.array(yy_axis)"
      ],
